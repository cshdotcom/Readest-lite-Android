{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "readest-shell",
  "version": "0.1.0",
  "identifier": "com.readest.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "阅读",
        "url": "https://YOUR_READER_DOMAIN.example.com"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
